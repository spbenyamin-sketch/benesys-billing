From 823b861e58c70d7ca26b4503c9df3de75b6f5dbb Mon Sep 17 00:00:00 2001
From: BeneSys Fix <fix@benesys.in>
Date: Thu, 19 Mar 2026 12:46:11 +0000
Subject: [PATCH] fix: favicon replaced with BeneSys icon + improved Tab/Enter
 navigation

- Replaced Replit favicon with BeneSys.ico/favicon.png
- Added favicon.ico for better browser support
- Fixed Tab/Enter navigation: proper field order, no skipping
- Barcode input Enter fires search (not navigation)
- Date input Tab works natively, Enter moves to next
- Checkbox/radio Enter toggles, Tab moves
- Button Enter clicks then moves focus forward
---
 client/index.html                    |   1 +
 client/public/favicon.ico            | Bin 0 -> 14458 bytes
 client/public/favicon.png            | Bin 1145 -> 7436 bytes
 client/src/hooks/useTabNavigation.ts | 130 +++++++++++++--------------
 4 files changed, 62 insertions(+), 69 deletions(-)
 create mode 100644 client/public/favicon.ico

diff --git a/client/index.html b/client/index.html
index 9d46273..b1006d5 100644
--- a/client/index.html
+++ b/client/index.html
@@ -3,6 +3,7 @@
   <head>
     <meta charset="UTF-8" />
     <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
+    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
     <link rel="icon" type="image/png" href="/favicon.png" />
     <link rel="manifest" href="/manifest.json" />
     <meta name="theme-color" content="#1a1a1a" />
diff --git a/client/public/favicon.ico b/client/public/favicon.ico
new file mode 100644
index 0000000000000000000000000000000000000000..6a035172897a6529cb372a8d742f0f6cbd59d8af
GIT binary patch
