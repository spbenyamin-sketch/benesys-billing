diff --git a/client/src/index.css b/client/src/index.css
index a86e5fa..b415627 100644
--- a/client/src/index.css
+++ b/client/src/index.css
@@ -297,3 +297,8 @@
     inset: -1px;
   }
 }
+
+/* Auto-select text when clicking number inputs */
+input[type="number"]:focus {
+  select: all;
+}
