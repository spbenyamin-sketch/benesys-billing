PROC CHKDT
RETU



proc hed
?"STOCK REPORT LEDGER WISE AS ON DATE  :"+DTOC(DATE())
?repl("-",50)
?PADC("DATE",12)+"  "+PADC("PUR",8)+"  "+PADC("SALES",8)+"  "+PADC("STOCK-QTY",10)
?repl("-",50)
retu

PROCEDURE chkbar
IF !EMPTY(TBARCODE)
	SELECT PUR
	SET ORDER TO BARCODE
	SEEK ALLTRIM(TBARCODE)
	IF FOUND()
		TNAME=PUR.NAME
		TBARCODE=ALLTRIM(STR(PUR.SERIAL))
	ENDIF 	

	SELECT PUR
	SET ORDER TO SERIAL
	SEEK VAL(TBARCODE)
	IF FOUND()
		TNAME=PUR.NAME
		TBARCODE=ALLTRIM(STR(PUR.SERIAL))
	ENDIF 
ENDIF 

RETURN 


PROCEDURE chkbrandX
SELE PUR
set order to name
defi popu prdd1 from 1,1 shad COLO G+/N+,G+/N+,G+/N+,G+/N+,G+/N+,N+/W+;
title padc("Brand Name",45)+" "+"  RATE  " prompt field padr(name,45)+" "+STR(RRATE,7,2) scroll margin FONT 'CONSOLAS',18 STYLE "B"  
on sele popu prdd1 do selits1
acti popu prdd1 rest
SELE PUR
RETU


proc selits1X
TBARCODE=ALLTRIM(STR(PUR.SERIAL))
TNAME=PUR.NAME
SHOW GETS 
deac popu prdd1
RETU 


PROCEDURE CHKBRAND
IF !EMPTY(TBARCODE)
	RETURN 
ENDIF 
TITSEL=.F.
SELECT PUR
SET ORDER TO NAME 
GO TOP 
TDET='padr(ALLTRIM(name)+" "+ALLTRIM(BRANDNAME),45)+" "+STR(RRATE,7,2)+"    "+ALLTRIM(STR(SERIAL,7))+" "+DTOC(EXPDATE)+" "+STR(TAX,7,2)'
TDET1='padC("BRAND/QUALITY NAME",45)+" "+PADC("RATE",9)+"  "+PADC("BARCODE",9)+" "+PADC("EXP.DATE",12)+" "+PADC("TAX",10)'
DO POPUP WITH TDET,TDET1,"SUPPLIER MASTER",2,2,20,85,"Form1"
IF TITSEL=.T.
	DO selits1
	TITSEL=.F.
ENDIF 
SELECT PUR

proc selits1
TBARCODE=ALLTRIM(STR(PUR.SERIAL))
TNAME=PUR.NAME
deac popu prdd1
RETU 


