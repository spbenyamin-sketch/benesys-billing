TDATE={}
TINVNO=0
PRN=0
defi wind myprn from 7,26 to 15,53 shad colo SCHE 10 NONE
acti wind myprn
@ 0,0 say padc("PAYMENT ENTRY",28) colo sche 7
@ 2,2 SAY "ENTRY NO :" GET TINVNO SIZE 1,6 VALI CHKNO()
@ 4,2 SAY "PAYMENT DATE :" GET TDATE 
@ 6,2 GET prn PICTURE "@*hT \<Screen;\<Printer;\<Exit" 
read
rele wind myprn
if last()=27 or prn=3
	RETU
endif

SELE SALE
REPL ALL PAYDATE WITH TDATE FOR INVNO=TINVNO
SET SAFE OFF
SELECT *,(QTY*COST) AS AMOUNT FROM SALE WHERE INVNO=TINVNO INTO TABLE C:\TSALE
SELE TSALE
USE
!VB6\VFP98\VFP6.EXE VFPPRG3
SET DISP TO VGA25
RETU


PROC CHKNO
SELE SALE
SET ORDER TO INVNO
SEEK TINVNO
IF !FOUND()
	WAIT WIND "NO."+ALLT(STR(TINVNO))+" NOT FOUND" NOWA
	RETU 0
ENDI
IF FOUND()
	TDATE=SALE.PAYDATE
	SHOW GETS
ENDI
RETU
