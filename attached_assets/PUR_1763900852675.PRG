ON KEY LABE F4 DO GOS

IF USED("PUR")
	SELECT PUR
	USE
ENDI 
IF USED("SALMAS")
	SELECT SALMAS
	USE
ENDI 


IF !USED("PUR")
	SELECT 0
	USE PUR
ENDI 

IF !USED("SALMAS")
	SELECT 0
	USE SALMAS
ENDI 


Local oForm
oForm = CREATEOBJECT("TopForm1")
oForm.show()
_screen.Visible = .F. && Hide Screen

SET CONFIRM ON 
SELE PUR
set orde to SERIAL
SP=.T.

scatter memvar blank
DEFINE WINDOW PURWIND from 2,16 to 24,65 NONE;
COLOR w+/r+,w+/n+  shad FONT 'Consolas',15 STYLE "B" IN WINDOW Form1
ACTIVATE WINDOW PURWIND

HIDE WINDOW PURWIND
defi popu find from 1,1 shad colo g+/n+,g+/n+,g+/n+,GR+/N+;
PROM FIEL PADR(BRANDNAME,25)+"|"+PADR(NAME,25)+"|"+STR(PURNO,8)+"|"+DTOC(DATE)+"|"+STR(QTY,8,3)+"|"+STR(COST,7,2)+"|"+STR(RRATE,7,2) FONT 'Consolas',15 STYLE "B"

ACTI WINDOW PURWIND


XBAR=""
XDATE={}
XNO=0
XTBILL="EST"
TPNAME=""
do disp
CLEA GETS
do true with "PUR.PRG"
RELEASE WINDOW PURWIND
IF USED("PUR")
	SELECT PUR
	USE
ENDI 
IF USED("SALMAS")
	SELECT SALMAS
	USE
ENDI 

RETU

READ EVENTS

_screen.Visible = .T. && Show Screen

DEFINE CLASS TopForm1 as Form

ShowWindow = 2
Windowstate=2
Name = "Form1"
Caption =  "Stock Inward"
FontName = 'Consolas'
FontSize = 15
icon = "star.ico"
BACKCOLOR=RGB(250,150,150)
PROCEDURE Destroy

CLEAR EVENTS

ENDPROC

ENDDEFINE



proc disp
@ 18,1 SAY "F4 - FIND ITEMS" COLO W+/N+
@ 0,0 SAY PADC("STOCK INWARD",49) COLO W+/N+
@ 2,1 SAY "Entry No :" get m.purno SIZE 1,10 PICT "@K" VALI CHKPNO()
@ 2,24 SAY "DATE  :" GET M.DATE 
*@ 4,1 SAY "SCAN BAR:" get XBAR SIZE 1,35 PICT "@K" VALI CHKBAR()
@ 4,1 SAY "PARTY   :" GET TPNAME SIZE 1,30 pict "@K" WHEN .F.
@ 6,1 SAY "ITEM NAME :" GET M.CODE VALI CHKITEM() pict "@K"
@ 6,18 GET M.ITNAME WHEN .F. COLO R+/N+ SIZE 1,25 pict "@K"
@8,1 SAY "BRAND  NAME :" GET M.BRANDNAME VALI CHKBRAND() pict "@K" SIZE 1,18
@10,1 SAY "NAME & SIZE :" GET M.NAME SIZE 1,30 pict "@K" VALI CHKNAME()
*@10,30 SAY "HSN  CODE :" GET M.HSNCODE  pict "@K" SIZE 1,10
@12,1 SAY "PUR RATE  :" GET M.COST SIZE 1,8,2 VALI CHKCOST() pict "@K"
@12,22 SAY "QTY :" GET M.QTY vali !empt(m.qty) SIZE 1,8,2 pict "@K"
@12,37 SAY "TAX :" GET M.TAX WHEN .F. SIZE 1,5,2
@14,1 SAY "PR % " get m.MARGIN SIZE 1,5,2 PICT "@K" VALI CHKMARGIN()
@14,15 SAY "RP-RATE :" get m.rrate SIZE 1,8,2 PICT "@K" 
@14,34 SAY "MRP % " get m.MRPPER SIZE 1,5,2 PICT "@K" VALI CHKMRPPER()
@16,1 SAY "MRP-RATE :" get m.MRP SIZE 1,8,2 
*@18,1 SAY "RATE-TAX  :" get m.Brate SIZE 1,8,2 PICT "@K"
@16,24 SAY "EXP DATE :" get m.EXPDATE  PICT "@K" VALI M.DATE<M.EXPDATE ERROR "ENTRY VALIED EXPIRY DATE" 
*@20,1 SAY "BARCODE :" get m.BARCODE SIZE 1,35 PICT "@K" VALI CHKBARC()
@18,1 SAY "SERIAL :" GET M.SERIAL WHEN .F.
@18,21 SAY "PROFIT :" GET M.PROFIT WHEN .F. SIZE 1,7,2
@18,38 SAY "% " GET M.PRPER WHEN .F. SIZE 1,5,2
*@24,1 SAY "EXPIRE/DAMAGE QTY :" GET M.DQTY SIZE 1,8,2
@20,20 GET save ;
	PICTURE "@*HT Save;Cancel" ;
	SIZE 1,8,1 ;
	DEFAULT 1
retu

proc clr
scatter memvar  blank
XBAR=""
IF EMPT(XDATE)
	M.DATE=DATE()
ELSE
	M.DATE=XDATE
	M.INVNO=XNO
ENDI
M.EXPDATE=M.DATE+10
save = 2
show gets
retu




PROC CHKSUPP
SELE SUPMAS
SET ORDER TO NAME
GO TOP
DEFI POPU SUPM FROM 1,11 TO 15,30 PROM FIEL PADR(NAME,25)+"ł"+STR(CODE,5) ;
TITL PADC("PARTY NAME",25)+" "+PADL("CODE",5) COLO GB+/N+,W+/B+,GB+/N+,GB+/N+,GB+/N+ SHAD  FONT 'Consolas',15 STYLE "B"
ON SELE POPU SUPM DO SELSUPP
ACTI POPU SUPM
IF EMPT(M.SUPPNAME)
	SELECT PUR 
	RETU 0
ENDI
SELE PUR
RETU

PROC SELSUPP
M.CODE=SUPMAS.CODE
M.SUPPNAME=SUPMAS.NAME
SHOW GETS
DEAC POPU SUPM
RETU







PROC CHKITEM
SELE SALMAS
SET FILTER TO 
SET ORDER TO NAME
SET CONFIRM ON 
IF !EMPTY(M.CODE)
	SELECT SALMAS
	SET FILTER TO 
	SET FILTER TO ALLTRIM(CODE)=ALLTRIM(M.CODE)
ENDIF 
DEFI POPU SALM FROM 1,1 PROM FIEL PADR(NAME,35)+"|"+STR(TAX,7,2)+"|"+STR(CODE1,5);
TITL PADC("ITEM NAME",35)+" "+PADL("TAX",8)+" "+PADL("CODE",5) COLO GB+/N+,W+/B+,GB+/N+,GB+/N+,GB+/N+ SHAD  FONT 'Consolas',15 STYLE "B"
ON SELE POPU SALM DO SELMAST
ACTI POPU SALM 
IF EMPT(M.ITNAME)
	SELECT PUR 
	RETU 0
ENDI
SELE PUR
RETU

PROC SELMAST
M.CODE=SALMAS.CODE
M.ITNAME=SALMAS.NAME
M.CODE1=SALMAS.CODE1
M.TYPE=SALMAS.TYPE 
M.TAX=SALMAS.TAX
SHOW GETS
DEAC POPU SALM
RETU




PROC CHKCOST
IF M.COST=0
	SELECT PUR 
	RETU 0
ENDI
M.ARATE=ROUND(M.COST*((M.TAX/100)+1),0)
XDATE=M.DATE
SHOW GETS 
RETU



PROCEDURE CHKPNO
IF EMPTY(M.PURNO)
	RETURN 0
ENDIF 
IF USED("PURCHASE")
	SELECT PURCHASE
	USE
ENDI 
IF !USED("PURCHASE")
	SELECT 0
	USE PURCHASE 
ENDI 
SELECT PURCHASE
SET ORDER TO PURNO
SEEK M.PURNO
IF FOUND()
	M.DATE=PURCHASE.DATE
	M.PCODE=PURCHASE.PCODE
	TPNAME=PURCHASE.PNAME
ELSE
	MESSAGEBOX("PURCHASE ENTRY NOT GENRATED....",0)
	RETURN 0
ENDIF 
SHOW GETS 
IF USED("PURCHASE")
	SELECT PURCHASE
	USE
ENDI 
SELECT PUR
RETURN 


PROCEDURE CHKXB
IF XTBILL="EST"
	M.COMPANY=2
ELSE
	M.COMPANY=1
ENDIF
RETURN 



PROC CHKNAME
SELE NAME FROM PUR GROU BY NAME INTO CURS XDET1
DEFI POPU SALD1 FROM 1,11 TO 15,40 PROM FIEL PADR(NAME,50);
TITL PADC("BRAND NAME",30) COLO GB+/N+,W+/G+,GB+/N+,GB+/N+,GB+/N+ SHAD FONT 'Consolas',15 STYLE "B" 
ON SELE POPU SALD1 DO SELDET1
LOCATE FOR ALLTRIM(NAME)=ALLTRIM(M.NAME)
ACTI POPU SALD1 REST 
SELE PUR 
RETU

PROC SELDET1
M.NAME=XDET1.NAME
SHOW GETS
DEAC POPU SALD1
RETU

PROCEDURE CHKMRP
M.BRATE=ROUND((M.RRATE/((M.TAX/100)+1)),0)
*M.MRP=M.RRATE
M.PROFIT=ROUND(M.BRATE-M.COST,2) 
M.PRPER=ROUND(((M.BRATE-M.COST)/M.BRATE)*100,2)
IF M.COST>M.MRP OR M.RRATE>M.MRP
	WAIT WINDOW "CHECK THE RATE..." NOWA
	SELECT PUR 
	RETURN 0
ENDIF 
SHOW GETS 
RETURN 

PROCEDURE CHKMARGIN
M.RRATE=ROUND(M.COST+((M.COST*M.MARGIN)/100),0)
SHOW GETS
RETU 

PROCEDURE CHKMRPPER
IF M.RRATE=0 OR (M.COST=M.RRATE)
	WAIT WINDOW "CHECK RP RATE...." NOWAIT 
	RETURN -1
ENDIF 
IF M.MRPPER#0
	M.MRP=ROUND(M.RRATE+((M.RRATE*M.MRPPER)/100),0)
ENDIF 
SHOW GETS
RETU 




PROC CHKBRAND
SELE BRANDNAME FROM PUR GROU BY BRANDNAME INTO CURS XDET1
DEFI POPU SALD2 FROM 1,11 TO 15,40 PROM FIEL PADR(BRANDNAME,50);
TITL PADC("BRAND NAME",30) COLO GB+/N+,W+/G+,GB+/N+,GB+/N+,GB+/N+ SHAD FONT 'Consolas',15 STYLE "B" 
ON SELE POPU SALD2 DO SELDET2
LOCATE FOR ALLTRIM(BRANDNAME)=ALLTRIM(M.BRANDNAME)
ACTI POPU SALD2 REST 
SELE PUR 
RETU

PROC SELDET2
M.BRANDNAME=XDET1.BRANDNAME
SHOW GETS
DEAC POPU SALD2
RETU






PROCEDURE GOSX
SELE PUR
set order to name
defi popu prdd1 from 1,1 shad COLO G+/N+,G+/N+,G+/N+,G+/N+,G+/N+,N+/W+;
title padc("Brand Name",45)+" "+PADC("RATE",7)++" "+PADC("SERIAL",7) prompt field padr(name,40)+" "+STR(RRATE,7,2)+" "+ALLTRIM(STR(SERIAL,7,2)) scroll margin FONT 'CONSOLAS',14 STYLE "B"  
on sele popu prdd1 do selits1
acti popu prdd1 rest
SELE PUR
RELEASE WINDOW MYPRN 
RETU


proc selits1
RELEASE WINDOW MYPRN 
SELECT PUR
SCAT MEMV
SHOW GETS
DO PRIOR
DO NEXT
deac popu prdd1
RETU 


PROC GOS
TITSEL=.F.
SELECT PUR
SET ORDER TO NAME 
GO TOP 
TDET='padr(ALLTRIM(name)+" "+ALLTRIM(BRANDNAME),45)+" "+STR(RRATE,7,2)+"    "+ALLTRIM(STR(SERIAL,7))+" "+DTOC(EXPDATE)+" "+STR(TAX,7,2)'
TDET1='padC("BRAND/QUALITY NAME",45)+" "+PADC("RATE",9)+"  "+PADC("BARCODE",9)+" "+PADC("EXP.DATE",12)+" "+PADC("TAX",10)'
DO POPUP WITH TDET,TDET1,"SUPPLIER MASTER",2,2,20,85,"Form1"
IF TITSEL=.T.
	DO selits1
	TITSEL=.F.
ENDIF 
SELECT PUR
RETURN 

PROCEDURE CHKBARC
IF BBR=2
	RETURN 
ENDIF 
IF !EMPTY(M.BARCODE) AND LEN(ALLTRIM(M.BARCODE))<=3
	MESSAGEBOX("BARCODE MISTAKE",0,"STORE")
	SELECT PUR
	RETURN 0
ENDIF 
IF !EMPTY(M.BARCODE)
	SELECT * FROM PUR WHERE !EMPTY(BARCODE) AND ALLTRIM(BARCODE)=ALLTRIM(M.BARCODE) INTO CURS BCC
	SELECT BCC
	COUNT TO X
	IF X>1
		MESSAGEBOX("BARCODE MATCHED WITH OTHER PRODUCT PLEASE CHECK OR USE STORE BARCODE",0,"STORE")
		SELECT bcc	
		defi popu prdd1 from 1,1 shad COLO G+/N+,G+/N+,G+/N+,G+/N+,G+/N+,N+/W+;
		title padc("Brand Name",45)+" "+PADC("RATE",7)+" "+PADC("SERIAL",7)+" "+PADC("EXP DATE",7) prompt field padr(name,40)+" "+STR(RRATE,7,2)+" "+ALLTRIM(STR(SERIAL,7,2))+" "+DTOC(EXPDATE) scroll margin FONT 'CONSOLAS',14 STYLE "B"  
		on sele popu prdd1 do selits2
		acti popu prdd1 rest
		SELECT PUR
		*RETURN 0
	ENDIF 
ENDIF 
SELECT PUR
RETURN 



proc selits2
SELECT PUR
deac popu prdd1
RETU 

PROCEDURE chkbar
IF !EMPTY(XBAR) AND ALLTRIM(XBAR)#'0'
	SELECT PUR
	SET ORDER TO DATE DESCENDING 
	LOCATE FOR ALLTRIM(BARCODE)=ALLTRIM(XBAR)
	IF FOUND()
		M.CODE=PUR.CODE
		M.ITNAME=PUR.ITNAME
		M.BRANDNAME=PUR.BRANDNAME
		M.HSNCODE=PUR.HSNCODE
		M.NAME=PUR.NAME
		M.COST=PUR.COST
		M.TAX=PUR.TAX
		M.COST=PUR.COST
		M.ARATE=PUR.ARATE 				
		M.RRATE=PUR.RRATE 				
		M.BRATE=PUR.BRATE 				
		M.EXPDATE=PUR.EXPDATE
		M.BARCODE=PUR.BARCODE
	ENDIF 
	SHOW GETS 
ENDIF 
IF !EMPTY(XBAR) AND ALLTRIM(XBAR)='0'
	TITSEL=.F.
	SELECT PUR
	SET ORDER TO NAME 
	GO TOP 
	TDET='padr(ALLTRIM(name)+" "+ALLTRIM(BRANDNAME),45)+" "+STR(RRATE,7,2)+"    "+ALLTRIM(STR(SERIAL,7))+" "+DTOC(EXPDATE)+" "+STR(TAX,7,2)'
	TDET1='padC("BRAND/QUALITY NAME",45)+" "+PADC("RATE",9)+"  "+PADC("BARCODE",9)+" "+PADC("EXP.DATE",12)+" "+PADC("TAX",10)'
	DO POPUP WITH TDET,TDET1,"SUPPLIER MASTER",2,2,20,85,"Form1"
	IF TITSEL=.T.
		M.CODE=PUR.CODE
		M.ITNAME=PUR.ITNAME
		M.BRANDNAME=PUR.BRANDNAME
		M.HSNCODE=PUR.HSNCODE
		M.NAME=PUR.NAME
		M.COST=PUR.COST
		M.TAX=PUR.TAX
		M.COST=PUR.COST
		M.ARATE=PUR.ARATE 				
		M.RRATE=PUR.RRATE 				
		M.BRATE=PUR.BRATE 				
		M.EXPDATE=PUR.EXPDATE
		M.BARCODE=PUR.BARCODE
		TITSEL=.F.
	ENDIF 
	SHOW GETS 
	SELECT PUR
ENDIF 
RETURN 
