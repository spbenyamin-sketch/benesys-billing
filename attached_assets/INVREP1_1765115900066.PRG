?repl("-",60)
?PADC("DATE",10)+" "+PADC("INV.NO",10)+" "+PADC("TIME",7)+"   "+PADR("SALE AMT",10)+" "+PADR("TAX AMT",8)+" "+PADR("NET.AMT",10)
?repl("-",60)
retu


proc hed2
?PADC("INVOICE REPORT",40)
?repl("-",60)
?PADC("DATE",10)+" "+PADC("TAX",10)+"   "+PADR("SALE AMT",10)+" "+PADR("TAX AMT",8)+" "+PADR("NET.AMT",10)
?repl("-",60)
retu

proc hed1
?PADC("INVOICE REPORT",40)
?repl("-",40)
