Local oForm
oForm = CREATEOBJECT("TopForm1")
oForm.show()
_screen.Visible = .F. && Hide Screen

SET CONFIRM ON 
prn=0
sl=0
pg=0
TBILL1="ALL"
TRTYPE="NORMAL"
dw=chr(27)+chr(33)+chr(46)
dwc=chr(27)+CHR(33)+CHR(8)
dh=chr(27)+chr(119)+chr(1)
dhc=chr(27)+chr(119)+chr(128)
ep=chr(27)+chr(33)+chr(8)
epc=chr(27)+chr(70)
ds=chr(27)+chr(71)
dsc=chr(27)+chr(72)
cp=chr(27)+CHR(33)+CHR(11)
cpc=CHR(27)+CHR(33)+CHR(8)
lqc=chr(27)+chr(120)+chr(0)
lq=chr(27)+chr(120)+chr(1)
cp12=chr(27)+chr(77)
cp12c=chr(27)+chr(78)
UND=CHR(27)+"-1"
UNDC=CHR(27)+"-0"
SELE SALE
TDT=DATE()
FDT=DATE()


defi wind MYPRN2 from 8,21 to 14,60 shad colo w+/r+,w+/n+ none FONT 'Consolas',15 STYLE "B" IN WINDOW Form1
acti wind MYPRN2
@ 0,0 say padc("ENTRY REPORT",45) colo w+/n+
@ 2,1 SAY "FROM :" GET FDT
@ 2,21 SAY "TO :" GET TDT 
@ 4,2 GET TBILL1 PICT "@MK ALL,GST,EST,TAX" VALI CHKINO()
@ 4,8 GET TRTYPE PICT "@MK NORMAL,TAX" WHEN TBILL1="GST"
@ 4,15 GET prn PICTURE "@*hT \<Screen;\<Printer;\<Exit" 
read
if last()=27 or prn=3
	rele wind MYPRN2
	SELE SALE
	SET FILT TO
	IF USED("PARTY")
		SELECT PARTY
		USE
	ENDI 
	IF USED("MAINSALE")
		SELECT MAINSALE
		USE
	ENDI 
	IF USED("SALE")
		SELECT SALE
		USE
	ENDI 
	RETU
endif
set curs off
set cons off
do case
	case prn = 1
		set safe off
		set alte to out.txt
		set alte on
		set safe on
		defi wind crea from 8,25 to 13,55 doub shad colo sche 10 FONT 'Consolas',15 STYLE "B" 
		acti wind crea
		@ 1,8 say "Creating Report"
		@ 2,8 say "Please Wait ..." colo W*/w+
	case prn = 2
		defi wind crea from 8,25 to 13,55 doub shad colo sche 10 FONT 'Consolas',15 STYLE "B" 
		acti wind crea
		@ 1,8 say "Printing Report"
		@ 2,8 say "Please Wait ..." colo W*/w+
		set cons off
    	*set prin on
    
 	case prn = 3
		SELE SALE
		SET FILT TO
   		set proc to
   		retu
	endc

stot=0

if prn=1
	store '' to cp,cpc,ep,epc,DW,DWC,LQ,LQC,dh,dhc,DS,DSC
else
	??chr(27)+chr(67)+chr(0)+chr(12)
endif
TAMT=0

SET SAFE OFF	
IF TBILL1#"ALL"
	IF TBILL1="GST"
		TCOMPANY=1
	ENDIF 
	IF TBILL1="TAX"
		TCOMPANY=2
	ENDIF 
	IF TBILL1="EST"
		TCOMPANY=3
	ENDIF 
	IF TRTYPE="NORMAL"
		SELECT MOBILE,TIME,COMPANY,FCODE,FDT AS FDT,TDT AS TDT,TAX,DATE,PADC(ALLTRIM(FCODE)+ALLT(STR(INVNO)),10) AS INVNO,AMOUNT,GTOT,CUSTNAME AS PNAME,CUSTCITY AS CITY,TIN AS GSTNO,SALEVALUE,TAXVALUE,ROF,GTOT AS NETAMT FROM MAINSALE WHERE COMPANY=TCOMPANY AND DATE>=FDT AND DATE<=TDT INTO TABLE SALEMAIN ORDER BY INVNO
	ELSE
		SELECT MOBILE,TIME,COMPANY,FCODE,FDT AS FDT,TDT AS TDT,TAX,DATE,STR(TAX,5,2) AS INVNO,SUM(SALVAL) AS SALEVALUE,SUM(SALTAX) AS TAXVALUE,SUM(AMOUNT) AS NETAMT FROM SALE WHERE COMPANY=TCOMPANY AND DATE>=FDT AND DATE<=TDT INTO TABLE SALEMAIN ORDER BY DATE,TAX GROUP BY DATE,TAX
	ENDIF 
	SELE SUM(SALTAX) AS SALTAX,SUM(SALVAL) AS SALVAL,TAX,CTAX,STAX,SUM(CGST) AS CGST,SUM(SGST) AS SGST FROM SALE GROU BY TAX INTO CURS TTAX WHER COMPANY=TCOMPANY AND DATE>=FDT AND DATE<=TDT
ELSE
	SELECT MOBILE,TIME,COMPANY,FCODE,FDT AS FDT,TDT AS TDT,TAX,DATE,PADC(ALLTRIM(FCODE)+ALLT(STR(INVNO)),10) AS INVNO,AMOUNT,GTOT,CUSTNAME AS PNAME,CUSTCITY AS CITY,TIN AS GSTNO,SALEVALUE,TAXVALUE,ROF,GTOT AS NETAMT FROM MAINSALE WHERE  DATE>=FDT AND DATE<=TDT INTO TABLE SALEMAIN
	SELE SUM(SALTAX) AS SALTAX,SUM(SALVAL) AS SALVAL,TAX,CTAX,STAX,SUM(CGST) AS CGST,SUM(SGST) AS SGST FROM SALE GROU BY TAX INTO CURS TTAX WHER DATE>=FDT AND DATE<=TDT
ENDI
SELECT SALEMAIN
IF TBILL1="GST"
	IF TRTYPE="NORMAL"
		DO HED
	ELSE
		DO HED2
	ENDIF 
	TNETAMT=0
	TSALVAL=0
	TTAXVAL=0
	SELE SALEMAIN
	SCAN 
		?DTOC(DATE)+"  "+PADC(INVNO,10)+" "+SUBSTR(TIME,1,5)+" "+STR(SALEVALUE,10,2)+" "+STR(TAXVALUE,8,2)+" "+STR(NETAMT,10,2)+IIF(MOBILE#0," "+ALLTRIM(STR(MOBILE,10)),"")
		TSALVAL=TSALVAL+SALEVALUE
		TTAXVAL=TNETAMT+TAXVALUE
		TNETAMT=TNETAMT+NETAMT
	ENDS
	?REPL("-",60)
	?SPAC(20)+STR(TSALVAL,10,2)+STR(TTAXVAL,10,2)+STR(TNETAMT,10,2)
	?REPL("-",60)
	SELECT TTAX
	TCGST=0
	TSGST=0
	TSVAL=0
	?
	?
	?REPL("-",40)
	?PADC("TAX",8)+PADC("VALUE",12)+PADC("CGST",6)+PADC("AMT",8)+PADC("SGST",6)+PADC("AMT",8)
	?REPL("-",40)
	SCAN
		TCGST=TCGST+CGST
		TSGST=TSGST+SGST
		TSVAL=TSVAL+SALVAL
		?STR(TAX,5,2)+" % "+STR((SALVAL),10,2)+" "+STR((CTAX*100),5,2)+'%'+STR((CGST),8,2)+STR((STAX*100),5,2)+'%'+STR((SGST),8,2)
	ENDS
	?REPL("-",45)
	?SPAC(13)+STR((TSVAL),10,2)++STR((TCGST),8,2)+SPAC(8)+STR((TSGST),8,2)
	?REPL("-",45)
	
ELSE
	DO HED1
	TNETAMT=0
	SELE SALEMAIN
	SCAN 
		?DTOC(DATE)+"  "+PADC(INVNO,10)+" "+SUBSTR(TIME,1,5)+" "+STR(NETAMT,10,2)+IIF(MOBILE#0," "+ALLTRIM(STR(MOBILE,10)),"")
		TNETAMT=TNETAMT+NETAMT
	ENDS
	?REPL("-",40)
	?SPAC(20)+STR(TNETAMT,10,2)
	?REPL("-",40)
ENDI

	IF TBILL1="ALL"
		SELE COMPANY,SPACE(15) AS TIN,SPACE(25) AS PARTY,INVNO,DATE,0000000.00 AS TOTVAL,SPACE(40) AS POS,"N" AS RES,SPACE(1) AS TX,"Regular" as taxtype,SPACE(1) as ec,tax,SUM(SALVAL) AS SALVAL,SUM(SALTAX) AS SALTAX,SUM(CGST) AS CGST,SUM(SGST) AS SGST,0000000.00 AS IGST,00 AS GTYPE FROM SALE GROU BY INVNO,TAX INTO TABL GSTR1 WHER DATE>=FDT AND DATE<=TDT 
	ELSE
		SELE COMPANY,SPACE(15) AS TIN,SPACE(25) AS PARTY,INVNO,DATE,0000000.00 AS TOTVAL,SPACE(40) AS POS,"N" AS RES,SPACE(1) AS TX,"Regular" as taxtype,SPACE(1) as ec,tax,SUM(SALVAL) AS SALVAL,SUM(SALTAX) AS SALTAX,SUM(CGST) AS CGST,SUM(SGST) AS SGST,0000000.00 AS IGST,00 AS GTYPE FROM SALE GROU BY INVNO,TAX INTO TABL GSTR1 WHER DATE>=FDT AND DATE<=TDT AND COMPANY=TCOMPANY
	ENDIF 
	SELECT GSTR1
	SCAN
		SELECT MAINSALE
		GO TOP
		LOCATE FOR INVNO=GSTR1.INVNO AND DATE=GSTR1.DATE AND COMPANY=MAINSALE.COMPANY
		IF FOUND()
			SELECT GSTR1
			REPLACE TIN WITH MAINSALE.TIN
			REPLACE PARTY WITH MAINSALE.CUSTNAME
			REPLACE TOTVAL WITH MAINSALE.GTOT	
			REPLACE POS WITH SUBS(ALLTRIM(MAINSALE.TIN),1,2)+"-"+ALLTRIM(MAINSALE.STATE)
			REPLACE GTYPE WITH MAINSALE.GSTTYPE 
		ENDIF 
		SELECT GSTR1
	ENDSCAN 
	SELECT GSTR1
	REPLACE ALL IGST WITH CGST+SGST FOR GTYPE=2
	REPLACE ALL CGST WITH 0,SGST WITH 0 FOR GTYPE=2
	COPY TO C:\TEMP\GSTR1 TYPE XLS 
	SELECT GSTR1
	USE
	SELECT * FROM SALE WHERE (TYPE='S' OR EMPTY(TYPE)) AND EMPTY(HSNCODE) AND DATE>=FDT AND DATE<=TDT INTO CURSOR TSHSN
	SELECT TSHSN
	SCAN
		WAIT WINDOW "HSN REPLACE...." NOWAIT 
		TSINV=TSHSN.INVNO
		TSDT=TSHSN.DATE
		TSCOMP=TSHSN.COMPANY
		SELECT * FROM SALE WHERE INVNO=TSINV AND DATE=TSDT AND COMPANY=TSCOMP AND QTY#0 INTO CURSOR TSSS
		SELECT TSSS
		GO TOP
		XXHSN=TSSS.HSNCODE
		SELECT SALE
		REPLACE HSNCODE WITH XXHSN FOR (TYPE='S' OR EMPTY(TYPE)) AND INVNO=TSINV AND DATE=TSDT AND COMPANY=TSCOMP
		SELECT TSHSN
	ENDS
	
	
	
	IF TBILL1="ALL"
		SELE SPACE(15) AS TIN,INVNO,DATE,COMPANY,00 AS GTYPE,HSNCODE,TAX,IIF(TYPE='M','NOS-KG     ','NOS-NUMBER') AS UQC,IIF(TYPE='M',SUM(VAL(SIZE)*QTY),SUM(QTY)) AS QTY,SUM(SALVAL) AS SALVAL,SUM(SALTAX) AS SALTAX,SUM(CGST) AS CGST,SUM(SGST) AS SGST,0000000.00 AS IGST FROM SALE GROU BY INVNO,DATE,HSNCODE,TAX INTO TABL HSN1 WHER DATE>=FDT AND DATE<=TDT 
	ELSE
		SELE SPACE(15) AS TIN,INVNO,DATE,COMPANY,00 AS GTYPE,HSNCODE,TAX,IIF(TYPE='M','NOS-KG     ','NOS-NUMBER') AS UQC,IIF(TYPE='M',SUM(VAL(SIZE)*QTY),SUM(QTY)) AS QTY,SUM(SALVAL) AS SALVAL,SUM(SALTAX) AS SALTAX,SUM(CGST) AS CGST,SUM(SGST) AS SGST,0000000.00 AS IGST FROM SALE GROU BY INVNO,DATE,HSNCODE,TAX INTO TABL HSN1 WHER DATE>=FDT AND DATE<=TDT AND COMPANY=TCOMPANY
	ENDIF 
	SCAN
		SELECT MAINSALE
		GO TOP
		LOCATE FOR INVNO=HSN1.INVNO AND DATE=HSN1.DATE AND COMPANY=MAINSALE.COMPANY
		IF FOUND()
			SELECT HSN1
			REPLACE GTYPE WITH MAINSALE.GSTTYPE 
			IF LEN(ALLTRIM(MAINSALE.TIN))=15
				REPLACE TIN WITH MAINSALE.TIN
			ENDIF 
		ENDIF 
		SELECT HSN1
	ENDSCAN 
	SELECT HSN1
	REPLACE ALL IGST WITH CGST+SGST FOR GTYPE=2
	REPLACE ALL CGST WITH 0,SGST WITH 0 FOR GTYPE=2
	SELE HSNCODE,"" AS DES,UQC,SUM(QTY) AS QTY,SUM(SALVAL+SALTAX) AS TOTVAL,TAX,SUM(SALVAL) AS TAXVAL,SUM(IGST) IGST,SUM(CGST) AS CGST,SUM(SGST) AS SGST,000000 AS CESS FROM HSN1 GROU BY HSNCODE,UQC,TAX INTO TABL HSN WHER !EMPTY(TIN)
	SELECT HSN
	COPY TO C:\TEMP\HSNB2B TYPE XLS 
	SELECT HSN
	USE
	SELE HSNCODE,"" AS DES,UQC,SUM(QTY) AS QTY,SUM(SALVAL+SALTAX) AS TOTVAL,TAX,SUM(SALVAL) AS TAXVAL,SUM(IGST) IGST,SUM(CGST) AS CGST,SUM(SGST) AS SGST,000000 AS CESS FROM HSN1 GROU BY HSNCODE,UQC,TAX INTO TABL HSN WHER EMPTY(TIN)
	SELECT HSN
	COPY TO C:\TEMP\HSNB2C TYPE XLS 
	SELECT HSN
	USE
	SELECT HSN1
	USE


IF USED("TTAX")
	SELECT TTAX
	USE
ENDIF 

SELE SALEMAIN
USE
IF PRN=2
	IF ALLT(TBILL1)="GST"
		IF TRTYPE="NORMAL"
			REPORT FORM invrep.frx  NOCONSOLE PREVIEW IN WINDOW Form1 
		ELSE
			REPORT FORM invrepG.frx  NOCONSOLE PREVIEW IN WINDOW Form1 
		ENDIF 
	ELSE
		REPORT FORM invrep1.frx  NOCONSOLE PREVIEW IN WINDOW Form1 
	ENDIF 
ENDI


