SELE SALE
SCAN FOR (DATE>=FINALDATE AND DATE<=FINALDATE1) AND INVNO=TINVNO1 AND COMPANY=TCOMPANY
	IF TYPE="P"
		XQTY=QTY
	ELSE
		XQTY=VAL(SIZE)*QTY
	ENDIF 
	?PADR(NAME,19)+"  "+STR(RATE,7,2)+"  "+STR(XQTY,8,2)+"  "+STR(AMOUNT,8,2)
	IF !EMPTY(QUALITY)
		?ALLT(QUALITY)
	ENDIF 
	TAMT=TAMT+AMOUNT
	XTQTY=XTQTY+XQTY
ENDS
XTAMT=TAMT

IF TBILL1="GST"
	TFR=15
	SELE SUM(SALTAX) AS SALTAX,SUM(SALVAL) AS SALVAL,TAX,CTAX,STAX,SUM(CGST) AS CGST,SUM(SGST) AS SGST FROM SALE GROU BY TAX INTO CURS TTAX WHER (DATE>=FINALDATE AND DATE<=FINALDATE1) AND INVNO=TINVNO1 AND COMPANY=TCOMPANY
	SELE TTAX
	TCGST=0
	TSGST=0
	?
	IF TINCTAX=.F.
		IF TGSTTYPE=1 OR TGSTTYPE=0
			?SPAC(5)+PADC("TAX",10)+PADC("CGST",6)+PADC("AMT",8)+PADC("SGST",6)+PADC("AMT",8)
			?SPAC(5)+REPL("-",40)
			SCAN
				TCGST=TCGST+CGST
				TSGST=TSGST+SGST
				?SPAC(5)+STR(TAX,6,2)+" % "+STR((CTAX*100),5,2)+'%'+STR((CGST),8,2)+STR((STAX*100),5,2)+'%'+STR((SGST),8,2)
			ENDS
			?SPAC(5)+REPL("-",40)
			?SPAC(18)+STR((TCGST),8,2)+SPAC(8)+STR((TSGST),8,2)
			?SPAC(5)+REPL("-",40)
		ELSE
			?SPAC(5)+PADC("IGST",23)+PADC("AMT",10)
			?SPAC(5)+REPL("-",40)
			SCAN
				TCGST=TCGST+CGST
				TSGST=TSGST+SGST
				?SPAC(5)+PADC(STR(TAX,6,2)+" % ",25)+STR((SGST+CGST),8,2)
			ENDS
			?SPAC(5)+REPL("-",40)
			?SPAC(30)+STR((TCGST+TSGST),8,2)
			?SPAC(5)+REPL("-",40)
		ENDIF 
		TAMT=ROUND(TAMT+TCGST+TSGST,0)
		TROF=TAMT-(XTAMT+TCGST+TSGST)
		IF TROF#0
			?PADL("ROUND OFF",33)+STR(TROF,8,2)
		ENDI
	ELSE
		IF TGSTTYPE=1 OR TGSTTYPE=0
			?PADC("TAX",10)+PADC("VALUE",10)+PADC("CGST",6)+PADC("AMT",8)+PADC("SGST",6)+PADC("AMT",8)
			?SPAC(5)+REPL("-",40)
			SCAN
				TCGST=TCGST+CGST
				TSGST=TSGST+SGST
				?STR(TAX,6,2)+" % "+STR((SALVAL),8,2)+" "+STR((CTAX*100),5,2)+'%'+STR((CGST),8,2)+STR((STAX*100),5,2)+'%'+STR((SGST),8,2)
			ENDS
			?REPL("-",45)
			?SPAC(23)+STR((TCGST),8,2)+SPAC(8)+STR((TSGST),8,2)
			?REPL("-",45)
		ELSE
			?PADC("TAX",10)+PADC("VALUE",10)+PADC("AMT",10)
			?+REPL("-",40)
			SCAN
				TCGST=TCGST+CGST
				TSGST=TSGST+SGST
				?PADC(STR(TAX,6,2)+" % ",10)+"  "+STR((SALVAL),8,2)+"  "+STR((SGST+CGST),8,2)
			ENDS
			?SPAC(5)+REPL("-",40)
			?SPAC(30)+STR((TCGST+TSGST),8,2)
			?SPAC(5)+REPL("-",40)
		ENDIF 
		TAMT=ROUND(TAMT,0)
		TROF=TAMT-(XTAMT)
		IF TROF#0
			?PADL("ROUND OFF",33)+STR(TROF,8,2)
		ENDI
	ENDIF 

ELSE
	TFR=16
	TAMT=ROUND(TAMT,0)
	TROF=TAMT-XTAMT
	IF TROF#0
		?PADL("ROUND OFF",33)+STR(TROF,8,2)
	ENDI
ENDI

?REPL("-",52)
?SPAC(30)+STR(XTQTY,8,2)+"  "+STR(TAMT,8,2)+CPC
?REPL("-",52)

?
?
?"GIVEN   : "+STR(TGIVEN,8,2)+" RETRUN : "+STR(TRETURN,8,2)
?
?"BY CARD : "+STR(XBYCARD,8,2)
?"BY CASH : "+STR(XBYCASH,8,2)


?
?


