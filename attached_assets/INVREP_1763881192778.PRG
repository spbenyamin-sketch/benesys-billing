proc hed
pg=pg+1
SELECT MAINSALE
GO TOP
LOCATE FOR (DATE>=FINALDATE AND DATE<=FINALDATE1) AND COMPANY=TCOMPANY AND INVNO=TINVNO1
IF MAINSALE.COMPANY=1
	?PADC(ALLT(COMP.BNAME),52)
	?PADC(ALLT(COMP.ADD),52)
	?PADC(ALLT(COMP.CITY),52)
	?PADC("GST NO :"+ALLT(COMP.GST),52)
	?
	?PADC("SALES BILL",52)
	?PADC("~~~~~~~~~~~~~~~~",52)
	SELE MAINSALE
ELSE
	?PADC(ALLT(COMP.ANAME),52)
	?PADC(ALLT(COMP.CITY),52)
	?
	?PADC("E S T I M A T E ",52)
	?PADC("~~~~~~~~~~~~~~~~",52)
	?

	SELE MAINSALE
ENDI
?
?repl("-",52)
?"BILL NO :"+ALLT(STR(MAINSALE.INVNO,7))+SPAC(6)+"DATE: "+DTOC(MAINSALE.DATE)
?repl("-",52)
?CP+PADC("ITEM NAME",19)+"  "+PADL("RATE",7)+"  "+PADL("QTY.",8)+"  "+PADL("AMOUNT",8)+CPC
?repl("-",52)
retu




