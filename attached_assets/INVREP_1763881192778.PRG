PROC CHKNO
SELE MAINSALE
SET ORDER TO INVNO
GO TOP 
LOCATE FOR (DATE>=FINALDATE AND DATE<=FINALDATE1) AND COMPANY=TCOMPANY AND INVNO=TINVNO1
IF !FOUND()
	WAIT WIND "NO."+ALLT(STR(TINVNO1))+" NOT FOUND" NOWA
	RETU 0
ELSE
TGSTTYPE=MAINSALE.GSTTYPE
SHOW GETS
ENDI
RETU

PROC CHKINO
IF TBILL1="GST"
	TCOMPANY=1
ENDIF 
IF TBILL1="TAX"
	TCOMPANY=2
ENDIF 
IF TBILL1="EST"
	TCOMPANY=3
ENDIF 
