TPNAME=""
IF EMPT(XTB)
	TBILL="EST"
ELSE
	TBILL=XTB
ENDI 
TAGENT=SPAC(30)
TAGE="ALL"
TTYPE="NEW"
TINVNO=0
DEFINE WINDOW XX from 7,32 to 10,70 COLO W+/N+ NONE FONT 'Consolas',15 STYLE "B" IN WINDOW MAIN
ACTI WIND XX
@ 1,1 SAY "TYPE :" GET TTYPE PICT "@M NEW,OLD,DEL"
@ 1,15 GET TBILL PICT "@M EST,GST"
@ 1,20 SAY "BILL NO :" GET TINVNO VALI CHKINV() WHEN ALLT(TTYPE)="OLD" OR  ALLT(TTYPE)="DEL" SIZE 1,5
READ
RELE WIND XX

SELE SALE
DO CASE
	CASE TTYPE="NEW"
		SET FILT TO BTYPE=TBILL
		set orde to INVNO
		GO BOTT
		TINVNO=SALE.INVNO+1
		SET FILT TO BTYPE=TBILL AND INVNO=TINVNO
	CASE TTYPE="OLD"
		SET FILT TO BTYPE=TBILL
		set orde to INVNO
		SET FILT TO BTYPE=TBILL AND INVNO=TINVNO
	CASE TTYPE="DEL"
		SELE SALE
		WAIT WIND "PRESS Y TO DELETE OR PRESS R TO RECOVER THE BILL NUMBER -> "+ALLT(STR(TINVNO)) TO "YN"
		IF UPPER(ALLT(YN))="Y"
			DELE FOR INVNO=TINVNO AND BTYPE=TBILL
			WAIT WIND "BILL DELETED -> "+ALLT(STR(TINVNO)) NOWA 
		ENDI 
		IF UPPER(ALLT(YN))="R"
			RECA FOR INVNO=TINVNO AND BTYPE=TBILL
			WAIT WIND "BILL RECOVERD -> "+ALLT(STR(TINVNO)) NOWA 
		ENDI 
		RETU 		
ENDC
SP=.T.

IF TBILL="EST"
	XCLR="W+/B+,W+/N+"  
	XCLR1="GR+/B+"
ELSE
	XCLR="W+/R+,W+/N+"
	XCLR1="GR+/R+"
ENDI 

defi popu find from 1,1 TO 24,60 shad colo g+/n+,g+/n+,g+/n+,GR+/N+;
PROM FIEL PADR(ITEMNAME,35)+"|"+STR(COST,10,2)+"|"+STR(QTY,8,3) title padc("Item Name",35)+" "+padc("Rate",12)+" "+padc("Qty",10) FONT 'Consolas',15 STYLE "B" 

scatter memvar blank
DEFINE WINDOW salm from 0,8 to 30,68 NONE;
COLOR &XCLR FONT 'Consolas',15 STYLE "B" IN WINDOW MAIN
ACTIVATE WINDOW salm
XDATE={}
XNO=0
do disp
DO SHOWBILL
CLEA GETS
do true with "SALE.PRG"
RELEASE WINDOW salm
on key labe f1
ON KEY LABEL F10
SELE SALE
SET FILT TO
IF BOPEN=.T.
	XTB=TBILL
	do INVREP WITH 2,TINVNO,TBILL
	KEYB "{ENTER}"
	KEYB "{ENTER}"
	KEYB "{ENTER}"
	KEYB "{ENTER}"
ENDI
BOPEN=.F.
XTB=""
RETU


proc disp
@ 0,0 SAY PADC("SALES",60) COLO W+/N+
@ 2,1 SAY "AGENT :" GET TAGE PICT "@M ALL,AGN"
@ 2,14  GET TAGENT SIZE 1,25 VALI CHKAGENT() WHEN TAGE="AGN"
@ 3,1 SAY "PARTY :" GET M.PNAME VALI CHKPARTY() SIZE 1,30
@ 4,1 SAY "DATE  :" GET M.DATE
@ 4,25 SAY "BILL NO :" GET M.INVNO VALI !EMPT(M.INVNO) WHEN .F.
@ 4,50 SAY "F10-PRINT" COLO GR+/N+
@ 5,1 SAY "ITEM  :" GET M.ITCODE VALI CHKITEM()
@ 5,20 GET M.ITEMNAME WHEN .F. COLO R+/N+ SIZE 1,30
@ 6,1 SAY "RATE  :" GET M.COST SIZE 1,10,2 VALI CHKCOST()
@ 6,20 SAY "QTY     :" GET M.QTY vali CHKQTY() SIZE 1,10,3
@ 6,43 GET save ;
	PICTURE "@*HT Save;Cancel" ;
	SIZE 1,8,1 ;
	DEFAULT 1
retu

proc clr
scatter memvar  blank
IF EMPT(XDATE)
	M.DATE=DATE()
ELSE
	M.DATE=XDATE
	M.INVNO=XNO
ENDI
M.INVNO=TINVNO
IF !EMPT(TPNAME)
	M.PNAME=TPNAME
ENDI
M.BTYPE=TBILL
save = 2
DO SHOWBILL
show gets
retu




PROC CHKITEM
TITCHK=.F.
SELE SALMAS
SET ORDER TO NAME
GO TOP
IF M.ITCODE=0
	DEFI POPU SALMX FROM 1,5 TO 19,62 PROM FIEL PADR(NAME,35)+"|"+STR(COST,6,2)+"|"+STR(CODE,5);
	TITL PADC("ITEM NAME",35)+" "+PADC("RATE",10)+" "+PADC("CODE",5) COLO GB+/N+,W+/G+,GB+/N+,GB+/N+,GB+/N+ SHAD FONT 'Consolas',15 STYLE "B"  
	ON SELE POPU SALMX DO SELMAST
	ACTI POPU SALMX
ELSE
	TITCHK=.T.
	DO SELMAST
ENDI
IF EMPT(M.ITEMNAME)
	RETU 0
ENDI
SELE SALE
RETU

PROC SELMAST
IF TITCHK=.T.
	SELE SALMAS
	SET ORDE TO CODE
	SEEK M.ITCODE
ENDI 
XTCOST=0
M.ITCODE=SALMAS.CODE
M.ITEMNAME=SALMAS.NAME
M.COST=SALMAS.COST
IF ALLT(TBILL)='GST'
	M.TAX=SALMAS.TAX
	M.CTAX=SALMAS.CTAX
	M.STAX=SALMAS.STAX
ENDI 
SELE SALE
SET FILT TO
SELE ITCODE,ITEMNAME,COST FROM SALE WHER ITCODE=M.ITCODE AND PCODE=M.PCODE INTO CURS TRATES ORDE BY DATE DESC
SELE TRATES
GO TOP
XTCOST=TRATES.COST
IF XTCOST#0
	WAIT WIND "LAST BILL RATE "+ALLT(STR(XTCOST,10,2)) NOWA 
	M.COST=XTCOST
ENDI
SELE SALE
SET FILT TO BTYPE=TBILL AND INVNO=TINVNO
SHOW GETS
DEAC POPU SALMX
RETU




PROC CHKCOST
IF M.COST=0
	RETU 0
ENDI
XDATE=M.DATE
XNO=M.INVNO
RETU






PROC CHKPARTY
SELE PARTY
SET ORDER TO PNAME
IF TAGE="ALL"
	SET FILT TO
ELSE
	SET FILT TO ALLT(AGENT)=ALLT(TAGENT)
ENDI
IF EMPT(M.PNAME)
	defi popu findx from 1,1 shad colo g+/n+,g+/n+,g+/n+,GR+/N+;
	title padc("Name",30) prom fiel padr(Pname,35)+"-"+padr(city,25) FONT 'Consolas',15 STYLE "B" 
	on sele popu findx do selfindx
	acti popu findx
ELSE
	LOCAT FOR ALLT(PNAME)=ALLT(TPNAME)
ENDI
SELE PARTY
SET FILT TO
IF EMPT(M.PNAME)
	WAIT WIND "PLEASE SELECT PARTY NAME" NOWA
ENDI 
sele sale
retu



proc selfindx
TPNAME=party.pname
m.pname=party.pname
m.add1=party.add1
m.CITY=party.CITY
m.tin=party.tin
M.AGENT=PARTY.AGENT
M.PCODE=PARTY.PCODE
@2,40 SAY ALLT(M.CITY)
show gets
deac popu findx
retu

PROC CHKQTY
IF M.QTY=0
	RETU 0
ENDI
M.CGST=(M.QTY*M.COST)*M.CTAX
M.SGST=(M.QTY*M.COST)*M.STAX
RETU 

PROC  CHKINV
IF TTYPE="DEL"
	RETU 
ENDI 
IF TINVNO=0  
	RETU 0
ENDI 
SELE SALE
SET ORDE TO INVNO
GO TOP 
LOCAT FOR BTYPE=TBILL AND INVNO=TINVNO
IF !FOUND()
	WAIT WIND "BILL NOT FOUND...." NOWA
	RETU 0
ELSE
	TPNAME=SALE.PNAME
	TAGENT=SALE.AGENT
ENDI
RETU


PROC SHOWBILL
@ 7,0 SAY PADC("BILL DETAILS SALES",59) COLO G+/N+
@ 8,0 SAY "S.NO"+" "+PADC("ITEMNAME",23)+" "+PADC("QTY",8)+" "+PADC("RATE",10)+" "+PADC("AMOUNT",10) COLO GR+/N+
TX=9
SELE SALE
SUM QTY,COST*QTY TO XQTY,XTOT FOR INVNO=TINVNO
GO TOP
TX1=1
SCAN FOR INVNO=TINVNO
	@ TX,1 SAY STR(TX1,3)+"|"+PADR(ITEMNAME,25)+"|"+STR(QTY,8,2)+"|"+STR(COST,8,2)+"|"+STR((COST*QTY),10,2)
	TX=TX+1
	TX1=TX1+1
	IF TX1>=19
		EXIT
	ENDI
ENDS
@ TX,1 TO TX,58
@ 28,1 SAY PADC("TOTAL",20)+STR(XQTY,10,2)+SPAC(8)+STR(XTOT,10,2) COLO &XCLR1 FONT 'Consolas',18 STYLE "B"
RETU 




PROC CHKagent
sele agent from party into curs tag grou by ageNt
sele tag
defi popu finda from 1,1 shad colo g+/n+,g+/n+,g+/n+,GR+/N+;
title padc("Agent",30) prom fiel padr(agent,35) FONT 'Consolas',15 STYLE "B"
on sele popu finda do selag
acti popu finda
sele sale
retu



proc selag
Tagent=tag.agent
show gets
deac popu finda
retu
