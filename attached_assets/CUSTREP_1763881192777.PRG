IF USED("CUST")
	SELECT CUST
	USE
ENDI 
IF !USED("CUST")
	SELECT 0
	USE CUST 
ENDI 

Local oForm
oForm = CREATEOBJECT("TopForm1")
oForm.show()
_screen.Visible = .F. && Hide Screen

SET CONFIRM ON 

SELE CUST
SET ORDE TO DATE
GO TOP
FDATE=CUST.DATE
GO BOTT
TDATE=CUST.DATE
SAVe=1
DEFI WIND XX FROM 8,20 TO 14,58 COLO W+/RB+ DOUB NOSHAD TITLE "CUSTOMER REPORT" FONT 'Consolas',15 STYLE "B" IN WINDOW Form1
ACTI WIND XX
@ 1,1 SAY "FROM :" GET FDATE 
@ 1,19 SAY "TO :" GET TDATE 
@ 3,1 GET save PICT "@*HT Screen;Cancel;Laser;Excel" ;
	SIZE 1,8,1 ;
	DEFAULT 1
READ
IF LAST()=27 OR SAVE=2
	IF USED("CUST")
		SELECT CUST
		USE
	ENDI 
	RELE WIND XX
	RETU
ENDI
RELE WIND XX

SET SAFE OFF
SET CONS OFF
SET ALTE TO C:\OUT.TXT
SET ALTE ON

SELE *,FDATE AS FD,TDATE AS TD FROM CUST WHER (DATE>=FDATE AND DATE<=TDATE) INTO CURS AA ORDE BY MOBILE
SL=0
?PADC("C U S T O M E R    R E P O R T",65)
?REPL("-",65)
?PADC("MOBILE",10)+"  "+PADC("CUSTOMER NAME",25)+"  "+PADC("CITY",15)+" "+PADC("PHONE NO",10)
?REPL("-",65)
TDT={  -  -    }
SELE AA
COUNT TO A
SCAN 
	IF DATE#TDT
		TDT=DATE
		IF SL#0
			?REPL("-",65)
			?"TOTAL CUSTOMER  :  "+ALLT(STR(SL))
			?REPL("-",65)
		ENDI
		?
		?"DATE : "+DTOC(TDT)
		?REPL("*",16)
		SL=0
	ENDI 
	?PADL(ALLT(STR(MOBILE)),10)+"  "+PADL(NAME,25)+"  "+PADL(CITY,15)
	TDT=DATE
	SL=SL+1
ENDS
?REPL("-",65)
?"TOTAL MEMBER  :  "+ALLT(STR(SL))
?REPL("-",65)
IF USED("CUST")
	SELECT CUST
	USE
ENDI 
set curs on
set cons on
IF SAVE=1
	set alte off
	set alte to
	modi file C:\out.txt IN WINDOW  Form1 NOEDIT 
ENDI
IF SAVE=3 OR save=4
	SET SAFE OFF
	IF 1=2
	SELE CITY,COUNT(*) AS CNT FROM AA INTO CURS CC GROU BY CITY
	SELE A.*,B.CNT FROM AA A,CC B WHER A.CITY=B.CITY INTO CURS AA1
	SELE * FROM AA1 ORDE BY CNT DESC INTO TABL C:\XX
	ENDIF 
	SELE FDATE AS FD,TDATE AS TD,* FROM CUST WHER (DATE>=FDATE AND DATE<=TDATE) ORDE BY DATE,MOBILE INTO TABL C:\XX
	IF SAVE=4
		SELECT XX
		COPY TO D:\CUSTOMER.XLS TYPE XLS 
		WAIT WINDOW "DATA SAVED TO D:\CUSTOMER.XLS...." NOWAIT 
	ENDIF 
	SELE XX
	USE
	IF SAVE=3
		REPORT FORM CUSTREP.frx NOEJECT NOCONSOLE PREVIEW IN WINDOW Form1
	ENDIF 
ENDI
RETURN 

READ EVENTS

_screen.Visible = .T. && Show Screen

DEFINE CLASS TopForm1 as Form

ShowWindow = 2
Windowstate=2
Name = "Form1"
Caption =  "Customer Report"
FontName = 'Consolas'
FontSize = 15
icon = "star.ico"
BACKCOLOR=RGB(250,150,150)
PROCEDURE Destroy

CLEAR EVENTS

ENDPROC
ENDDEFINE
