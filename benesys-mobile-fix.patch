diff --git a/client/src/index.css b/client/src/index.css
index b415627..6048993 100644
--- a/client/src/index.css
+++ b/client/src/index.css
@@ -302,3 +302,109 @@
 input[type="number"]:focus {
   select: all;
 }
+
+/* ============================================================
+   MOBILE / PWA RESPONSIVE FIXES
+   ============================================================ */
+
+/* Prevent horizontal overflow on all pages */
+html, body {
+  overflow-x: hidden;
+  width: 100%;
+  max-width: 100vw;
+}
+
+/* Safe area insets for PWA on iOS (notch/home bar) */
+body {
+  padding-top: env(safe-area-inset-top);
+  padding-bottom: env(safe-area-inset-bottom);
+  padding-left: env(safe-area-inset-left);
+  padding-right: env(safe-area-inset-right);
+}
+
+/* All pages: prevent content overflow */
+main {
+  overflow-x: hidden;
+  max-width: 100vw;
+}
+
+/* Tables: horizontal scroll on mobile instead of overflowing */
+.table-responsive {
+  overflow-x: auto;
+  -webkit-overflow-scrolling: touch;
+  max-width: 100%;
+}
+
+table {
+  min-width: 100%;
+}
+
+/* Cards: full width on mobile */
+@media (max-width: 640px) {
+  .card, [class*="Card"] {
+    border-radius: 0.5rem;
+  }
+  
+  /* Reduce padding on mobile */
+  .p-6 { padding: 0.75rem !important; }
+  .p-4 { padding: 0.5rem !important; }
+  .px-6 { padding-left: 0.75rem !important; padding-right: 0.75rem !important; }
+  .px-4 { padding-left: 0.5rem !important; padding-right: 0.5rem !important; }
+  
+  /* Stack grid columns on mobile */
+  .grid-cols-2, .grid-cols-3, .sm\:grid-cols-2, .lg\:grid-cols-3 {
+    grid-template-columns: 1fr !important;
+  }
+
+  /* Make inputs full width */
+  input[type="text"],
+  input[type="number"],
+  input[type="date"],
+  input[type="email"],
+  select,
+  textarea {
+    max-width: 100% !important;
+    font-size: 16px !important; /* Prevents iOS zoom on focus */
+  }
+
+  /* Smaller text in table cells */
+  td, th {
+    font-size: 0.75rem;
+    padding: 0.25rem 0.375rem;
+  }
+
+  /* Sidebar: hide on mobile by default (already handled by shadcn) */
+  
+  /* Bill summary panel: show below items on mobile */
+  .bill-summary-panel {
+    width: 100% !important;
+  }
+
+  /* Fix header on mobile */
+  header {
+    flex-wrap: wrap;
+    gap: 0.25rem;
+  }
+}
+
+/* Table inputs on mobile: smaller */
+@media (max-width: 768px) {
+  .w-16 { width: 3.5rem; }
+  .w-20 { width: 4rem; }
+  
+  /* Make table container scrollable */
+  [class*="overflow-auto"], [class*="overflow-x-auto"] {
+    -webkit-overflow-scrolling: touch;
+  }
+}
+
+/* PWA standalone mode specific */
+@media (display-mode: standalone) {
+  body {
+    padding-top: env(safe-area-inset-top);
+  }
+  
+  header {
+    padding-top: 0;
+  }
+}
