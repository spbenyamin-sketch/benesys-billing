From e291b289e6cbe9b96d5d8d87bfb561d8312fe3b8 Mon Sep 17 00:00:00 2001
From: BeneSys Fix <fix@benesys.in>
Date: Thu, 19 Mar 2026 13:32:57 +0000
Subject: [PATCH] fix: PWA mobile responsive - all pages fit screen properly
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- viewport-fit=cover for iOS notch/safe area support
- Added safe-area-inset padding for PWA standalone mode
- Prevent horizontal overflow on all pages (overflow-x: hidden)
- Font size 16px on inputs (prevents iOS auto-zoom on focus)
- Reduced padding on mobile (p-4/p-6 → smaller)
- Grid columns stack to 1 col on mobile
- Smaller table cell padding/font on mobile
- App layout: min-w-0 prevents flex overflow
- mobile-web-app-capable meta for Android PWA
---
 client/index.html    |   4 +-
 client/src/App.tsx   |  12 ++---
 client/src/index.css | 106 +++++++++++++++++++++++++++++++++++++++++++
 3 files changed, 115 insertions(+), 7 deletions(-)

diff --git a/client/index.html b/client/index.html
index 4662084..d7b7dca 100644
--- a/client/index.html
+++ b/client/index.html
@@ -2,7 +2,7 @@
 <html lang="en">
   <head>
     <meta charset="UTF-8" />
-    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
+    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, viewport-fit=cover" />
     <link rel="shortcut icon" href="/favicon.ico?v2" type="image/x-icon" />
     <link rel="icon" type="image/x-icon" href="/favicon.ico?v2" sizes="any" />
     <link rel="icon" type="image/png" href="/favicon-32.png?v2" sizes="32x32" />
@@ -10,6 +10,8 @@
     <link rel="manifest" href="/manifest.json" />
     <meta name="theme-color" content="#1a1a1a" />
     <meta name="description" content="GST-compliant billing and inventory management system for retail businesses" />
+    <meta name="mobile-web-app-capable" content="yes" />
+    <meta name="apple-touch-fullscreen" content="yes" />
     <meta name="apple-mobile-web-app-capable" content="yes" />
     <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
     <meta name="apple-mobile-web-app-title" content="BeneSys" />
