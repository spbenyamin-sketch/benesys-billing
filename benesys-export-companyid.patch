From 600b7cccea9a5cd1e4fd6791b97e5746a15b4489 Mon Sep 17 00:00:00 2001
From: BeneSys Fix <fix@benesys.in>
Date: Fri, 20 Mar 2026 11:04:49 +0000
Subject: [PATCH] fix: add X-Company-Id header to export fetch - was missing
 causing 'Company ID is required' error

---
 client/src/components/ImportExport.tsx | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/client/src/components/ImportExport.tsx b/client/src/components/ImportExport.tsx
index 36c02f6..a62b452 100644
--- a/client/src/components/ImportExport.tsx
+++ b/client/src/components/ImportExport.tsx
@@ -34,7 +34,10 @@ export function ImportExport({ type, queryKey }: ImportExportProps) {
   async function handleExport() {
     setExporting(true);
     try {
-      const res = await fetch(`/api/${type}/export`, { credentials: "include" });
+      const companyId = localStorage.getItem("currentCompanyId");
+      const headers: Record<string, string> = { "Content-Type": "application/json" };
+      if (companyId) headers["X-Company-Id"] = companyId;
+      const res = await fetch(`/api/${type}/export`, { credentials: "include", headers });
       if (!res.ok) {
         const errData = await res.json().catch(() => ({}));
         throw new Error(errData.message || "Export failed (" + res.status + ")");
